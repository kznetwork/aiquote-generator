# ─── OpenRouter API ──────────────────────────────────────────────────────────
# https://openrouter.ai/keys 에서 발급
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# 사용할 AI 모델 (선택 - 기본값: anthropic/claude-sonnet-4-5)
# 다른 모델 예시:
#   anthropic/claude-opus-4-5      (최고 성능, 비용 높음)
#   anthropic/claude-haiku-4-5     (빠르고 저렴)
#   openai/gpt-4o                  (OpenAI GPT-4o)
#   openai/gpt-4o-mini             (저렴한 GPT-4o)
#   google/gemini-2.5-pro          (Google Gemini)
# 전체 목록: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
